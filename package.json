{
  "name": "@unsent/sdk",
  "version": "1.1.0",
  "description": "TypeScript SDK for the Unsent API - Send transactional & marketing emails with ease",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsup index.ts --format esm,cjs --dts",
    "test": "vitest",
    "publish-sdk": "pnpm run build && pnpm publish --no-git-checks --access public",
    "openapi:generate": "openapi-typescript ../../apps/docs/public/api-reference.json -o src/types/schema.d.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/unsent-dev/unsent-typescript.git"
  },
  "homepage": "https://unsent.dev",
  "bugs": {
    "url": "https://github.com/unsent-dev/unsent-typescript/issues"
  },
  "keywords": [
    "unsent",
    "email",
    "transactional-email",
    "marketing-email",
    "api",
    "sdk",
    "typescript",
    "react-email"
  ],
  "author": "Unsent <team@unsent.dev>",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "19.2.14",
    "@unsent/typescript-config": "workspace:*",
    "@unsent/vitest-config": "workspace:*",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@react-email/render": "^2.0.4",
    "react": "^19.2.4",
    "vitest": "^4.1.0"
  }
}
